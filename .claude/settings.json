{
  "model": "claude-sonnet-4-5",

  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(docker-compose *)",
      "Bash(docker compose *)",
      "Bash(uv run *)",
      "Bash(uv sync*)",
      "Bash(npm run *)",
      "Bash(npm install*)",
      "Bash(alembic *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(echo *)",
      "Read(**)",
      "Edit(**)",
      "Write(**)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf /*)",
      "Bash(sudo *)",
      "Read(**/.env)"
    ]
  },

  "hooks": {
    "PostToolUse": [{
        "matcher": "Edit|Write",
        "hooks": [{"type": "command", "command": "bash .claude/hooks/post_edit.sh"}]
    }],

    "PreToolUse": [{
        "matcher": "Bash",
        "hooks": [{"type": "command", "command": "bash .claude/hooks/git_guard.sh"}]
    }]
  }
}